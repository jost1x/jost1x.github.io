---
import { getCollection } from "astro:content";
import { Calendar } from "@lucide/astro";
import Reveal from "@/components/Reveal.astro";

const education = (await getCollection("education")).sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime(),
);

const certifications = (await getCollection("certifications")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const formatDate = (date) =>
  date.toLocaleDateString("es-CL", {
    year: "numeric",
    month: "short",
  });
---

<section id="learning" class="px-6 py-32" aria-labelledby="learning-heading">
  <div class="mx-auto max-w-5xl">
    <Reveal>
      <p id="learning-heading" class="text-primary mb-4 text-xs tracking-[0.2em] uppercase">
        Formacion
      </p>
    </Reveal>

    <Reveal delay={100}>
      <h2 class="text-foreground mb-12 text-2xl font-medium md:text-3xl">
        Formacion y aprendizaje continuo
      </h2>
    </Reveal>

    <Reveal delay={200}>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div>
          <h3 class="text-foreground mb-6 text-lg font-medium">
            Formacion academica
          </h3>

          <div class="space-y-6" role="list" aria-label="Formacion academica">
            {education.map((item) => (
              <article class="rounded-xl border border-white/6 bg-white/3 p-5 backdrop-blur-sm" role="listitem">
                <div class="mb-2 flex items-start justify-between gap-2">
                  <div>
                    <h4 class="text-foreground font-medium">
                      {item.data.degree}
                    </h4>
                    <p class="text-primary text-sm">
                      {item.data.institution}
                    </p>
                  </div>

                  <span class="text-muted-foreground inline-flex items-center gap-1.5 text-xs">
                    <Calendar class="h-3" aria-hidden="true" />
                    <time dateTime={item.data.startDate.toISOString()}>
                      {formatDate(item.data.startDate)}
                    </time>
                    {" — "}
                    {item.data.endDate ? (
                      <time dateTime={item.data.endDate.toISOString()}>
                        {formatDate(item.data.endDate)}
                      </time>
                    ) : (
                      "Actualidad"
                    )}
                  </span>
                </div>

                {item.data.summary && (
                  <p class="text-muted-foreground text-sm leading-relaxed">
                    {item.data.summary}
                  </p>
                )}
              </article>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-foreground mb-6 text-lg font-medium">
            Aprendizaje continuo
          </h3>

          <div class="space-y-4" role="list" aria-label="Certificaciones y cursos">
            {certifications.map((cert) => (
              <article class="rounded-xl border border-white/6 bg-white/3 p-4 backdrop-blur-sm" role="listitem">
                <div class="flex items-start justify-between gap-2">
                  <div>
                    <h4 class="text-foreground text-sm font-medium">
                      {cert.data.title}
                    </h4>
                    <p class="text-muted-foreground text-xs">
                      {cert.data.issuer}
                    </p>
                  </div>

                  <span class="text-muted-foreground text-xs">
                    <time dateTime={cert.data.date.toISOString()}>
                      {cert.data.date.getFullYear()}
                    </time>
                  </span>
                </div>

                {cert.data.credentialUrl && (
                  <a
                    href={cert.data.credentialUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary mt-2 inline-block text-xs hover:underline"
                  >
                    Ver credencial →
                  </a>
                )}
              </article>
            ))}
          </div>
        </div>
      </div>
    </Reveal>
  </div>
</section>
